{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(./scripts/validate-manifest)",
      "Bash(scripts/validate-manifest)",
      "Bash(./scripts/check-assessment:*)",
      "Bash(scripts/check-assessment:*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*secret*)",
      "Write(**/*credential*)",
      "Bash(gh:*)",
      "Bash(git push:*)",
      "Bash(git push origin main*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(eval:*)",
      "Bash(cat .env:*)",
      "Bash(grep .env:*)",
      "Bash(sed * .env*)",
      "Bash(awk * .env*)",
      "Bash(cp .env*:*)",
      "Bash(:*API_KEY:*)",
      "Bash(:*PASSWORD:*)",
      "Bash(:*SECRET:*)"
    ]
  }
}
