#!/usr/bin/env bash
# Backend bootstrap helper for the conversational qualification workflow.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
source "$SCRIPT_DIR/common.sh"

if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  C_CYAN="$(tput setaf 6)"
  C_GREEN="$(tput setaf 2)"
  C_YELLOW="$(tput setaf 3)"
  C_DIM="$(tput dim)"
  C_BOLD="$(tput bold)"
  C_RESET="$(tput sgr0)"
else
  C_CYAN="" C_GREEN="" C_YELLOW="" C_DIM="" C_BOLD="" C_RESET=""
fi

echo "${C_BOLD}${C_CYAN}=== Worth Building: Idea Qualification ===${C_RESET}"
echo ""
echo "This script bootstraps files for a business idea qualification pass."
echo "It follows the workflow defined in:"
echo "  ${C_DIM}core/prompts/workflows/qualify-idea.md${C_RESET}"
echo "  ${C_DIM}core/prompts/workflows/worth-building.md${C_RESET}"
echo "  ${C_DIM}core/prompts/workflows/assess-idea.md${C_RESET}"
echo ""
echo "${C_BOLD}Steps:${C_RESET}"
echo "  1. Gather context (idea brief)"
echo "  2. Qualification scoring"
echo "  3. Decision-critical market research"
echo "  4. Competitive analysis"
echo "  5. Revenue quality analysis"
echo "  6. Risk assessment"
echo "  7. Decision memo generation"
echo ""

if [ -z "${1:-}" ]; then
  echo "${C_YELLOW}Usage:${C_RESET} scripts/assess <idea-name>"
  echo "  e.g.: scripts/assess ai-hvac-scheduler"
  exit 1
fi

IDEA_INPUT="$*"
IDEA_KEY="$(resolve_idea_key "$IDEA_INPUT")"
ASSESSMENT_DIR="$ROOT/docs/assessments/$IDEA_KEY"
RESEARCH_DIR="$ROOT/docs/research/$IDEA_KEY"
ASSESSMENT_TEMPLATE_DIR="$ROOT/core/templates/assessments"
RESEARCH_TEMPLATE_DIR="$ROOT/core/templates/research"

mkdir -p "$ASSESSMENT_DIR" "$RESEARCH_DIR"
echo "Idea name: ${C_BOLD}$IDEA_INPUT${C_RESET}"
echo "Idea key:  ${C_BOLD}$IDEA_KEY${C_RESET}"
echo "${C_GREEN}Assessment directory ready:${C_RESET} $ASSESSMENT_DIR"
echo "${C_GREEN}Research directory ready:  ${C_RESET} $RESEARCH_DIR"
echo ""
echo "${C_CYAN}Bootstrapping assessment templates...${C_RESET}"

for name in idea-brief viability-score red-green-flags recommendations risk-assessment full-report executive-summary one-pager; do
  bootstrap_file "$ASSESSMENT_TEMPLATE_DIR/$name.md" "$ASSESSMENT_DIR/$name.md"
done

for name in market-overview trends segments sources competitors positioning-map moat-comparison revenue-model unit-economics financial-scenarios; do
  bootstrap_file "$RESEARCH_TEMPLATE_DIR/$name.md" "$RESEARCH_DIR/$name.md"
done

echo ""
echo "${C_BOLD}${C_GREEN}Ready for assessment.${C_RESET} Start with:"
echo "  ${C_DIM}docs/assessments/$IDEA_KEY/idea-brief.md${C_RESET}"
echo ""
echo "${C_BOLD}Workflow prompts:${C_RESET}"
echo "  ${C_DIM}core/prompts/workflows/qualify-idea.md${C_RESET}"
echo "  ${C_DIM}core/prompts/workflows/worth-building.md${C_RESET}"
echo "  ${C_DIM}core/prompts/workflows/assess-idea.md${C_RESET}"
echo ""
echo "Assessment files: ${C_DIM}$ASSESSMENT_DIR/${C_RESET}"
echo "Research files:   ${C_DIM}$RESEARCH_DIR/${C_RESET}"
echo ""
echo "${C_YELLOW}If this becomes a Build-now idea, prepare and export:${C_RESET}"
echo "  ${C_DIM}$ASSESSMENT_DIR/meta-template-handoff.md${C_RESET}"
echo "  ${C_DIM}scripts/export-handoff $IDEA_KEY${C_RESET}"
