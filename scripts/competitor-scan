#!/usr/bin/env bash
# Bootstrap the competitive analysis files for an idea assessment.
# Delegates to core/prompts/roles/competitive-analyst.md
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
source "$SCRIPT_DIR/common.sh"

echo "=== Worth Building: Competitive Scan ==="
echo ""

if [ -z "${1:-}" ]; then
  echo "Usage: scripts/competitor-scan <idea-name>"
  echo "  e.g.: scripts/competitor-scan ai-scheduling-saas"
  exit 1
fi

IDEA_INPUT="$*"
IDEA_KEY="$(resolve_idea_key "$IDEA_INPUT")"
ASSESSMENT_DIR="$ROOT/docs/assessments/$IDEA_KEY"
RESEARCH_DIR="$ROOT/docs/research/$IDEA_KEY"
TEMPLATE_DIR="$ROOT/core/templates/research"

mkdir -p "$RESEARCH_DIR"
if [ ! -d "$ASSESSMENT_DIR" ]; then
  echo "Warning: No assessment workspace found at $ASSESSMENT_DIR"
  echo "Run 'scripts/assess \"$IDEA_INPUT\"' first if this is a full qualification."
  echo ""
fi

echo "Competitive analysis directory: $RESEARCH_DIR"
echo ""
echo "Bootstrapping competitor analysis files..."
for name in competitors positioning-map moat-comparison; do
  bootstrap_file "$TEMPLATE_DIR/$name.md" "$RESEARCH_DIR/$name.md"
done
echo ""
echo "An AI agent will follow the role prompt in:"
echo "  core/prompts/roles/competitive-analyst.md"
echo ""
echo "Start with: $RESEARCH_DIR/competitors.md"
