#!/usr/bin/env bash
# One-command release flow for worth-building.
#
# Updates VERSION, prepends a release entry to CHANGELOG.md (replacing
# the [Unreleased] header), and stages both files. Prints — but does
# not run — the suggested commit + tag commands. Maintainer reviews
# the staged diff and runs the commands themselves.
#
# Usage:
#   scripts/release --patch                 # 0.1.0 -> 0.1.1
#   scripts/release --minor                 # 0.1.0 -> 0.2.0
#   scripts/release --major                 # 0.1.0 -> 1.0.0
#   scripts/release --version 1.2.3         # explicit
#   scripts/release --patch --dry-run       # preview only

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
VERSION_FILE="$ROOT/VERSION"
CHANGELOG_FILE="$ROOT/CHANGELOG.md"

if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  C_CYAN="$(tput setaf 6)"
  C_GREEN="$(tput setaf 2)"
  C_YELLOW="$(tput setaf 3)"
  C_RED="$(tput setaf 1)"
  C_BOLD="$(tput bold)"
  C_RESET="$(tput sgr0)"
else
  C_CYAN="" C_GREEN="" C_YELLOW="" C_RED="" C_BOLD="" C_RESET=""
fi

usage() {
  cat <<EOF
Usage: scripts/release [--patch | --minor | --major | --version X.Y.Z] [--dry-run]

  --patch          bump patch (0.1.0 -> 0.1.1)
  --minor          bump minor (0.1.0 -> 0.2.0)
  --major          bump major (0.1.0 -> 1.0.0)
  --version X.Y.Z  set explicit semver
  --dry-run        preview changes without writing

Reads VERSION, edits CHANGELOG.md, stages both. Does not commit, tag,
or push — review the staged diff and run those commands yourself.
EOF
}

BUMP=""
EXPLICIT_VERSION=""
DRY_RUN="0"

while [ $# -gt 0 ]; do
  case "$1" in
    --patch|--minor|--major)
      BUMP="${1#--}"
      shift
      ;;
    --version)
      EXPLICIT_VERSION="${2:-}"
      [ -n "$EXPLICIT_VERSION" ] || { echo "${C_RED}Error:${C_RESET} --version requires an argument" >&2; exit 1; }
      shift 2
      ;;
    --dry-run)
      DRY_RUN="1"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "${C_RED}Error:${C_RESET} unknown argument: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if [ -z "$BUMP" ] && [ -z "$EXPLICIT_VERSION" ]; then
  echo "${C_RED}Error:${C_RESET} specify --patch, --minor, --major, or --version X.Y.Z" >&2
  usage >&2
  exit 1
fi

if [ ! -f "$VERSION_FILE" ]; then
  echo "${C_RED}Error:${C_RESET} VERSION file not found at $VERSION_FILE" >&2
  exit 1
fi

if [ ! -f "$CHANGELOG_FILE" ]; then
  echo "${C_RED}Error:${C_RESET} CHANGELOG.md not found at $CHANGELOG_FILE" >&2
  exit 1
fi

CURRENT="$(tr -d '[:space:]' < "$VERSION_FILE")"

if ! printf '%s' "$CURRENT" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$'; then
  echo "${C_RED}Error:${C_RESET} VERSION file does not contain a valid semver: '$CURRENT'" >&2
  exit 1
fi

if [ -n "$EXPLICIT_VERSION" ]; then
  if ! printf '%s' "$EXPLICIT_VERSION" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+$'; then
    echo "${C_RED}Error:${C_RESET} --version must be X.Y.Z, got: '$EXPLICIT_VERSION'" >&2
    exit 1
  fi
  NEW="$EXPLICIT_VERSION"
else
  IFS='.' read -r MAJ MIN PAT <<< "$CURRENT"
  case "$BUMP" in
    patch) PAT=$((PAT + 1)) ;;
    minor) MIN=$((MIN + 1)); PAT=0 ;;
    major) MAJ=$((MAJ + 1)); MIN=0; PAT=0 ;;
  esac
  NEW="${MAJ}.${MIN}.${PAT}"
fi

if [ "$NEW" = "$CURRENT" ]; then
  echo "${C_YELLOW}Warning:${C_RESET} new version ($NEW) equals current version ($CURRENT). Nothing to do." >&2
  exit 1
fi

if ! grep -q '^## \[Unreleased\]' "$CHANGELOG_FILE"; then
  echo "${C_RED}Error:${C_RESET} CHANGELOG.md does not contain '## [Unreleased]' section to promote" >&2
  exit 1
fi

TODAY="$(date +%Y-%m-%d)"

echo "${C_BOLD}${C_CYAN}=== Release: $CURRENT -> $NEW ===${C_RESET}"
echo ""
echo "VERSION:    ${C_BOLD}$CURRENT${C_RESET} -> ${C_BOLD}${C_GREEN}$NEW${C_RESET}"
echo "CHANGELOG:  promote [Unreleased] to [$NEW] - $TODAY, insert fresh [Unreleased]"
echo "Date:       $TODAY"
echo ""

if [ "$DRY_RUN" = "1" ]; then
  echo "${C_YELLOW}Dry run — no files written.${C_RESET}"
  echo ""
  echo "Suggested commands after a real run:"
  echo "  ${C_CYAN}git commit -m \"Release v$NEW\"${C_RESET}"
  echo "  ${C_CYAN}git tag v$NEW${C_RESET}"
  echo "  ${C_CYAN}git push origin <current-branch> v$NEW${C_RESET}"
  exit 0
fi

# Update VERSION file
printf '%s\n' "$NEW" > "$VERSION_FILE"
echo "${C_GREEN}Updated:${C_RESET} VERSION"

# Update CHANGELOG: replace "## [Unreleased]" with the new section header,
# then re-insert a fresh "## [Unreleased]" right above it.
TMP="$(mktemp)"
awk -v new="$NEW" -v today="$TODAY" '
  /^## \[Unreleased\]/ && !done {
    print "## [Unreleased]"
    print ""
    print "## [" new "] — " today
    done = 1
    next
  }
  { print }
' "$CHANGELOG_FILE" > "$TMP"
mv "$TMP" "$CHANGELOG_FILE"
echo "${C_GREEN}Updated:${C_RESET} CHANGELOG.md"

# Stage both files
( cd "$ROOT" && git add VERSION CHANGELOG.md )
echo "${C_GREEN}Staged:${C_RESET}  VERSION + CHANGELOG.md"

echo ""
echo "${C_BOLD}Next steps (review the staged diff first):${C_RESET}"
echo "  ${C_CYAN}git diff --cached${C_RESET}                          # review changes"
echo "  ${C_CYAN}git commit -m \"Release v$NEW\"${C_RESET}"
echo "  ${C_CYAN}git tag v$NEW${C_RESET}"
echo "  ${C_CYAN}git push origin \$(git branch --show-current) v$NEW${C_RESET}"
echo ""
echo "${C_YELLOW}Note:${C_RESET} this script never pushes — you control when the tag goes public."
